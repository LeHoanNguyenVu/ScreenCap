<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111"
    android:weightSum="10"
    android:fitsSystemWindows="true">

    <com.example.sceencap.CropAdjustView
        android:id="@+id/view_crop_adjust"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:layout_margin="16dp"/>

    <LinearLayout
        android:id="@+id/layout_text_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical"
        android:background="#222222"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kết quả quét:"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:id="@+id/tv_scanned_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textIsSelectable="true" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_copy_original"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋 COPY GỐC"
                android:textStyle="bold"
                android:textSize="12sp"
                android:backgroundTint="#FF9800"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_copy_translated"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🇻🇳 COPY DỊCH"
                android:textStyle="bold"
                android:textSize="12sp"
                android:backgroundTint="#4CAF50"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_translate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌐 DỊCH (VI)"
                android:textStyle="bold"
                android:textSize="12sp"
                android:backgroundTint="#E91E63" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_ai_edit_dialog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Nhập ý tưởng để AI sửa ảnh:"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:gravity="center" />

        <EditText
            android:id="@+id/edt_ai_prompt"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:hint="Ví dụ: chuyển thành phong cách anime, xóa vật thể..."
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:textSize="14sp"
            android:background="#333333"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:imeOptions="actionDone"
            android:gravity="top|start"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"
            tools:ignore="NestedWeights" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 HƯỚNG DẪN: Ảnh đã được tự động thêm. Sang Gemini, bạn chỉ cần bấm DÁN (Paste) để nhập ý tưởng và gửi!"
            android:textColor="#FF5722"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_cancel_ai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❌ Hủy"
                android:textSize="12sp"
                android:backgroundTint="#555555"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_go_to_ai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="✨ CHUYỂN GEMINI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#6200EE" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#333333">

        <LinearLayout
            android:id="@+id/layout_normal_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="4dp">
                        <Button android:id="@+id/btn_cancel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="❌ Hủy" android:textSize="10sp" android:padding="8dp" android:backgroundTint="#555555" android:background="@drawable/shape_button_rounded" />
                        <ImageButton android:id="@+id/ib_help_cancel" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Hủy" tools:ignore="VectorDrawableCompat" /> </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="4dp">
                        <Button android:id="@+id/btn_search_image" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔍 TÌM" android:textSize="10sp" android:textStyle="bold" android:padding="8dp" android:backgroundTint="#FF5722" android:background="@drawable/shape_button_rounded" />
                        <ImageButton android:id="@+id/ib_help_search" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Tìm kiếm" tools:ignore="VectorDrawableCompat" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                        <Button android:id="@+id/btn_scan_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="📝 QUÉT" android:textSize="10sp" android:padding="8dp" android:textStyle="bold" android:backgroundTint="#9C27B0" android:background="@drawable/shape_button_rounded" />
                        <ImageButton android:id="@+id/ib_help_scan" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Quét chữ" tools:ignore="VectorDrawableCompat" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp"> <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="4dp">
                    <Button android:id="@+id/btn_share" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="📤 Share" android:textSize="10sp" android:padding="8dp" android:backgroundTint="#008CBA" android:background="@drawable/shape_button_rounded" />
                    <ImageButton android:id="@+id/ib_help_share" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Share" tools:ignore="VectorDrawableCompat" />
                </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="4dp">
                        <Button android:id="@+id/btn_ai_edit" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="✨ SỬA AI" android:textSize="10sp" android:textStyle="bold" android:padding="8dp" android:backgroundTint="#6200EE" android:background="@drawable/shape_button_rounded" />
                        <ImageButton android:id="@+id/ib_help_ai_edit" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Sửa AI" tools:ignore="VectorDrawableCompat" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                        <Button android:id="@+id/btn_save" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="💾 LƯU" android:textSize="10sp" android:padding="8dp" android:backgroundTint="#4CAF50" android:background="@drawable/shape_button_rounded"/>
                        <ImageButton android:id="@+id/ib_help_save" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_help_question" android:backgroundTint="@android:color/transparent" android:scaleType="centerInside" android:padding="16dp" android:contentDescription="Trợ giúp Lưu" tools:ignore="VectorDrawableCompat" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_help_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="italic"
                android:gravity="center"
                android:visibility="gone"
                android:background="@drawable/shape_button_rounded"
                android:backgroundTint="#2A2A2A" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_edit_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:visibility="gone"
            android:background="#222222">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💡 Gợi ý:\nNếu bạn muốn tìm sản phẩm: Hãy cắt ảnh sát vào sản phẩm để càng tìm được kết quả chính xác nhất." android:textColor="#FFEB3B" android:textSize="12sp" android:textStyle="italic" android:gravity="center" android:lineSpacingExtra="4dp" android:layout_marginBottom="12dp" />
            <Button android:id="@+id/btn_confirm_crop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✅ XÁC NHẬN CẮT" android:textStyle="bold" android:backgroundTint="#4CAF50" android:background="@drawable/shape_button_rounded"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>